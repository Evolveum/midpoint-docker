def repoName = params.REPOSITORY_NAME ?: 'midpoint'
def templateReg = params.TEMPLATE_REGISTRY ?: 'registry.evolveum.com/internal'
podTemplate(activeDeadlineSeconds: 7200, idleMinutes: 1, serviceAccount: 'jenkins', containers: [
    containerTemplate(
        name: "jnlp",
        image: "jenkins/inbound-agent:4.13-2-alpine-jdk11",
        runAsUser: '0',
        resourceLimitCpu: '900m',
        resourceLimitMemory: '1Gi',
        resourceRequestCpu: '900m',
        resourceRequestMemory: '1Gi'
    ),
    containerTemplate(
        name: "kubectl",
        image: "alpine:3.22",
        command: 'sh -c "apk add --no-cache bash curl kubectl=~1.33 && curl -sL https://github.com/google/go-containerregistry/releases/latest/download/go-containerregistry_Linux_x86_64.tar.gz | tar xzf - -C /usr/local/bin crane && cat"',
        runAsUser: '0',
        ttyEnabled: true,
    ),
  ]) {
    node(POD_LABEL) {
        stage ("create environment") {
            container ("kubectl") {
                    try {
                        sh """#!/bin/bash
timestamp="${JOB_NAME}-${BUILD_NUMBER}"
echo \${timestamp} >timestamp
mkdir logs-\${timestamp}
echo "Using Harbor registry ${templateReg} as staging..."
                        """
                    } catch (err) {
                        echo "Caught: ${err}"
                        unstable 'Error during environment initialization'
                    }
            }
        }
        stage ("build image") {
            container ("kubectl") {
                withKubeConfig([credentialsId: '6a647093-716e-4e8f-90bd-a8007be37f0e',
                        serverUrl: 'https://10.200.130.10:6443',
                        contextName: 'jenkins',
                        clusterName: 'kubernetes',
                        namespace: 'jenkins-legacy'
                        ]) {
                    try {
                        sh """#!/bin/bash
timestamp="\$(cat timestamp)"
cat <<EOF | kubectl apply -f -
apiVersion: v1
kind: Pod
metadata:
  name: kaniko-\${timestamp}
  namespace: jenkins-legacy
spec:
  volumes:
    - name: docker-config
      secret:
        secretName: harbor-pull-internal
        items:
          - key: .dockerconfigjson
            path: config.json
  containers:
    - name: kaniko
      image: gcr.io/kaniko-project/executor:latest
      args:
        - "--dockerfile=templates/Dockerfile-build"
        - "--context=git://github.com/Evolveum/midpoint-docker.git#refs/heads/master"
        - "--destination=${templateReg}/${repoName}:build-alpine-\${timestamp}"
        - "--build-arg=http_proxy=\${http_proxy}"
        - "--build-arg=https_proxy=\${https_proxy:-\${http_proxy}}"
        - "--build-arg=no_proxy=\${no_proxy}"
      volumeMounts:
        - name: docker-config
          mountPath: /kaniko/.docker
  restartPolicy: Never
EOF
echo "Waiting to finish the process of the image build..."
status=\$(kubectl get -n jenkins-legacy pod/kaniko-\${timestamp} -o=jsonpath="{.status.phase}")
while [ "\${status}" == "Pending" -o "\${status}" == "Running" ]
do
    sleep 15
    status=\$(kubectl get -n jenkins-legacy pod/kaniko-\${timestamp} -o=jsonpath="{.status.phase}")
    echo "Log contain \$(kubectl logs -n jenkins-legacy kaniko-\${timestamp} | wc -l) lines..."
done
echo " - - - - - - - -"
kubectl logs -n jenkins-legacy kaniko-\${timestamp} > logs-\${timestamp}/kaniko.log
kubectl delete -n jenkins-legacy pod/kaniko-\${timestamp}
                    """
                    } catch (err) {
                        echo "Caught: ${err}"
                        unstable 'Error during build phase'
                    }
                }
            }
        }
        stage ("test") {
            container ("kubectl") {
                try {
                    sh """#!/bin/bash
timestamp="\$(cat timestamp)"

crane auth login registry.evolveum.com -u "\$(kubectl get secret harbor-robot-internal-jenkins -n jenkins-legacy -o jsonpath='{.data.username}' | base64 -d)" -p "\$(kubectl get secret harbor-robot-internal-jenkins -n jenkins-legacy -o jsonpath='{.data.password}' | base64 -d)"

echo " . . . . Checking image in registry . . . ."
crane manifest ${templateReg}/${repoName}:build-alpine-\${timestamp} | tee logs-\${timestamp}/test.log
echo
echo " . . . . Image config . . . ."
crane config ${templateReg}/${repoName}:build-alpine-\${timestamp}
echo
echo " . . . . Crane version in image . . . ."
crane export ${templateReg}/${repoName}:build-alpine-\${timestamp} - | tar -xf - -O usr/local/bin/crane --to-stdout > /dev/null && echo "crane binary found in image" || echo "crane binary NOT found"
echo " . . . . OS release . . . ."
crane export ${templateReg}/${repoName}:build-alpine-\${timestamp} - | tar -xf - -O etc/os-release 2>/dev/null || echo "os-release not found"
                        """
                } catch (err) {
                    echo "Caught: ${err}"
                    unstable 'Error during test...'
                }
            }
        }
        stage ("push") {
            container ("kubectl") {
                try {
                    sh """#!/bin/bash
timestamp="\$(cat timestamp)"

crane auth login registry.evolveum.com -u "\$(kubectl get secret harbor-robot-internal-jenkins -n jenkins-legacy -o jsonpath='{.data.username}' | base64 -d)" -p "\$(kubectl get secret harbor-robot-internal-jenkins -n jenkins-legacy -o jsonpath='{.data.password}' | base64 -d)"

echo "Promoting build-alpine-\${timestamp} to build-alpine..."
crane copy ${templateReg}/${repoName}:build-alpine-\${timestamp} ${templateReg}/${repoName}:build-alpine
echo "Done."
crane manifest ${templateReg}/${repoName}:build-alpine
                        """
                } catch (err) {
                    echo "Caught: ${err}"
                    unstable 'Error during push...'
                }
            }
        }
         stage ("cleanup environment") {
            container ("kubectl") {
                    try {
                        sh """#!/bin/bash
timestamp="\$(cat timestamp)"

harborUser="\$(kubectl get secret harbor-robot-internal-jenkins -n jenkins-legacy -o jsonpath='{.data.username}' | base64 -d)"
harborPass="\$(kubectl get secret harbor-robot-internal-jenkins -n jenkins-legacy -o jsonpath='{.data.password}' | base64 -d)"

echo "Cleaning up build tag from Harbor..."
curl -s -u "\${harborUser}:\${harborPass}" -X DELETE "https://registry.evolveum.com/api/v2.0/projects/internal/repositories/${repoName}/artifacts/build-alpine-\${timestamp}/tags/build-alpine-\${timestamp}" || true
echo "Deleted tag: build-alpine-\${timestamp}"

echo "Preparing the archive with the logs..."
tar -cvzf logs.tgz logs-\${timestamp}
                    """
                    } catch (err) {
                        echo "Caught: ${err}"
                    }
                archiveArtifacts allowEmptyArchive: true, artifacts: 'logs.tgz', followSymlinks: false
            }
        }
    }
}
